<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Campo para el nombre del dispositivo -->
    <EditText
        android:id="@+id/deviceNameInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nombre del dispositivo" />

    <!-- Campo de autocompletado para el correo del usuario -->
    <AutoCompleteTextView
        android:id="@+id/userEmailInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Correo del usuario (opcional)"
        android:inputType="textEmailAddress" />

    <!-- Íconos para conexiones -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center"
        android:padding="16dp">

        <ImageView
            android:id="@+id/wifiIcon"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_wifi" />

        <ImageView
            android:id="@+id/bluetoothIcon"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_bluetooth" />
    </LinearLayout>

    <!-- Botón para registrar dispositivo -->
    <Button
        android:id="@+id/registerDeviceButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Registrar Dispositivo" />
</LinearLayout>
